Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# macOS 系统文件
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?

